{
  "type": "component",
  "metadata": {},
  "schema": {
    "name": "bb-component-SuperFieldOptions",
    "friendlyName": "Super Field - Options",
    "description": "An Option Input Field component for Budibase",
    "icon": "MultipleCheck",
    "requiredAncestors": ["form"],
    "block": true,
    "ejectable": false,
    "context": [
      {
        "type": "static",
        "values": [
          {
            "label": "Value",
            "key": "value",
            "type": "array"
          }
        ]
      }
    ],
    "settings": [
      {
        "type": "field/array",
        "label": "Field",
        "key": "field",
        "required": true
      },
      {
        "type": "text",
        "label": "Label",
        "key": "fieldLabel",
        "placeholder": "Field Name",
        "resetOn": "field"
      },
      {
        "type": "text",
        "label": "Placeholder",
        "key": "placeholder",
        "placeholder": "Choose Options"
      },
      {
        "type": "text",
        "label": "Default value",
        "key": "defaultValue",
        "supportsConditions": false
      },
      {
        "type": "text",
        "label": "Help text",
        "key": "helpText"
      },
      {
        "type": "validation/array",
        "label": "Validation",
        "key": "validation"
      },
      {
        "type": "event",
        "label": "On change",
        "key": "onChange",
        "context": [
          {
            "label": "Value",
            "key": "value"
          }
        ]
      },
      {
        "type": "select",
        "label": "Control Type",
        "key": "controlType",
        "defaultValue": "select",
        "placeholder": "Pick an options type",
        "options": [
          {
            "label": "Select",
            "value": "select"
          },
          {
            "label": "Checkboxes",
            "value": "checkbox"
          },
          {
            "label": "Switches",
            "value": "switch"
          }
        ]
      },
      {
        "type": "select",
        "label": "Arrangement",
        "key": "optionsArrangement",
        "defaultValue": 1,
        "showInBar": false,
        "barStyle": "buttons",
        "dependsOn": {
          "setting": "controlType",
          "value": "select",
          "invert": true
        },
        "options": [
          {
            "label": "1 column",
            "value": 1,
            "barIcon": "Stop",
            "barTitle": "1 column"
          },
          {
            "label": "2 columns",
            "value": 2,
            "barIcon": "ColumnTwoA",
            "barTitle": "2 columns"
          },
          {
            "label": "3 columns",
            "value": 3,
            "barIcon": "ViewColumn",
            "barTitle": "3 columns"
          }
        ]
      },
      {
        "type": "select",
        "label": "Options source",
        "key": "optionsSource",
        "defaultValue": "schema",
        "placeholder": "Pick an options source",
        "options": [
          {
            "label": "Schema",
            "value": "schema"
          },
          {
            "label": "Data",
            "value": "data"
          },
          {
            "label": "Custom",
            "value": "custom"
          }
        ]
      },
      {
        "section": true,
        "name": "Data Settings",
        "dependsOn": { "setting": "optionsSource", "value": "data" },
        "settings": [
          {
            "type": "boolean",
            "key": "fullTable",
            "label": "Super Table",
            "resetOn": ["optionsSource", "controlType"],
            "dependsOn": { "setting": "controlType", "value": "select" },
            "defaultValue": false
          },
          {
            "type": "dataSource",
            "label": "Data",
            "key": "datasource",
            "resetOn": "optionsSource"
          },
          {
            "type": "filter",
            "label": "Filtering",
            "key": "filter"
          },
          {
            "type": "field/sortable",
            "label": "Sort column",
            "key": "sortColumn",
            "placeholder": "None"
          },
          {
            "type": "select",
            "label": "Sort order",
            "key": "sortOrder",
            "options": ["Ascending", "Descending"],
            "defaultValue": "Ascending"
          },
          {
            "type": "number",
            "label": "Limit",
            "key": "limit",
            "defaultValue": 10
          },
          {
            "type": "field",
            "label": "Value column",
            "key": "valueColumn",
            "resetOn": ["datasource", "optionsSource"],
            "dependsOn": { "setting": "optionsSource", "value": "data" },
            "required": true
          },
          {
            "type": "field",
            "label": "Label column",
            "key": "labelColumn",
            "resetOn": "datasource",
            "dependsOn": { "setting": "fullTable", "value": false }
          },
          {
            "type": "boolean",
            "key": "prefetch",
            "label": "Prefetch",
            "dependsOn": {
              "setting": "fullTable",
              "value": true,
              "invert": true
            },
            "defaultValue": true
          },
          {
            "type": "boolean",
            "key": "cache",
            "label": "Cache",
            "dependsOn": {
              "setting": "fullTable",
              "value": true,
              "invert": true
            },
            "defaultValue": true
          }
        ]
      },
      {
        "section": true,
        "dependsOn": { "setting": "fullTable", "value": true },
        "name": "Super Table Options",
        "settings": [
          {
            "type": "columns",
            "label": "Columns",
            "key": "columnList",
            "resetOn": "datasource"
          }
        ]
      },
      {
        "type": "options",
        "key": "customOptions",
        "label": "Custom Options",
        "dependsOn": {
          "setting": "optionsSource",
          "value": "custom"
        }
      },
      {
        "type": "boolean",
        "label": "Debounced",
        "key": "debounced",
        "defaultValue": false
      },
      {
        "type": "number",
        "label": "Debounce Delay (ms)",
        "key": "debounceDelay",
        "minValue": "200",
        "defaultValue": 750,
        "dependsOn": "debounced"
      },
      {
        "type": "boolean",
        "label": "Autocomplete",
        "key": "autocomplete",
        "defaultValue": false,
        "dependsOn": {
          "setting": "controlType",
          "value": "select"
        }
      },
      {
        "type": "boolean",
        "label": "Disabled",
        "key": "disabled",
        "defaultValue": false
      },
      {
        "type": "boolean",
        "label": "Read only",
        "key": "readonly",
        "defaultValue": false,
        "dependsOn": {
          "setting": "disabled",
          "value": true,
          "invert": true
        }
      },
      {
        "type": "icon",
        "key": "icon",
        "label": "Inline Icon",
        "dependsOn": { "setting": "controlType", "value": "select" }
      },
      {
        "type": "boolean",
        "key": "customButtons",
        "label": "Add Buttons"
      },
      {
        "type": "buttonConfiguration",
        "key": "buttons",
        "nested": true,
        "dependsOn": "customButtons"
      },
      {
        "tag": "style",
        "type": "boolean",
        "key": "useOptionColors",
        "label": "Option Colors",
        "defaultValue": false
      },
      {
        "tag": "style",
        "type": "text",
        "label": "Option Color",
        "key": "colorTemplate",
        "dependsOn": "useOptionColors"
      },
      {
        "tag": "style",
        "type": "icon",
        "key": "optionsIcon",
        "label": "Options Icon"
      },
      {
        "tag": "style",
        "type": "text",
        "label": "Option Icon",
        "key": "iconTemplate"
      },
      {
        "tag": "style",
        "type": "select",
        "label": "Options Mode",
        "key": "optionsViewMode",
        "defaultValue": "text",
        "showInBar": true,
        "barStyle": "buttons",
        "dependsOn": { "setting": "controlType", "value": "select" },
        "options": [
          {
            "label": "Pills",
            "value": "pills",
            "barIcon": "Button"
          },
          {
            "label": "text",
            "value": "text",
            "barIcon": "Text"
          }
        ]
      },
      {
        "tag": "style",
        "type": "select",
        "label": "Layout",
        "key": "span",
        "defaultValue": 6,
        "showInBar": true,
        "barStyle": "buttons",
        "options": [
          {
            "label": "1 column",
            "value": 6,
            "barIcon": "Stop",
            "barTitle": "1 column"
          },
          {
            "label": "2 columns",
            "value": 3,
            "barIcon": "ColumnTwoA",
            "barTitle": "2 columns"
          },
          {
            "label": "3 columns",
            "value": 2,
            "barIcon": "ViewColumn",
            "barTitle": "3 columns"
          }
        ]
      }
    ]
  }
}
